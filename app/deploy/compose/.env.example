## MySQL
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=jellyfish
MYSQL_USER=jellyfish
MYSQL_PASSWORD=change-me
MYSQL_PORT=3306

## Redis / Celery Broker
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=
# 如需单独覆盖完整 broker 地址，可设置：
# CELERY_BROKER_URL=redis://redis:6379/0

## Backend
# 可选：如需真实调用大模型，再设置
# OPENAI_API_KEY=

## RustFS (S3 compatible)
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
S3_BUCKET_NAME=jellyfish-assets
RUSTFS_PORT=9000
RUSTFS_CONSOLE_PORT=9001

## server.bat (docker compose 无头模式) 对外发布的端口
# 故意跟 test.bat/run.bat 本地开发模式用的 8000/7788 错开，
# 这样两种模式的端口永远不会互相冲突，可以随时切换。
SERVER_BACKEND_PORT=18000
SERVER_FRONT_PORT=18080
# 容器实际发布在 127.0.0.1 上的"内部端口"，由 server.bat 的 portproxy
# 从上面的对外端口转发过来。必须与对外端口错开（WSL2 mirrored 模式
# 按端口号整机记账，同号复用会导致 LAN 访问被拒连），一般不用改。
SERVER_BACKEND_INTERNAL_PORT=28000
SERVER_FRONT_INTERNAL_PORT=28080

## Front runtime config (served as /env.js)
# 由于前后端分端口部署，浏览器应访问宿主机的后端地址。
# 注意：这里的 localhost 是相对"打开页面的浏览器"而言的，不是服务器自己。
# 只有浏览器和服务器是同一台机器时，localhost 才有效；
# 如果要给局域网/其他机器访问（例如 server.bat 场景），
# 必须换成服务器的真实局域网 IP，例如 http://192.168.1.10:18000
BACKEND_URL=http://localhost:18000

# 跨域白名单（逗号分隔），必须跟浏览器访问前端时地址栏里的“协议+主机+端口”完全一致。
# 局域网访问时需要把服务器的局域网 IP 也加进来，例如：
# CORS_ORIGINS=http://localhost:18080,http://127.0.0.1:18080,http://192.168.1.10:18080
CORS_ORIGINS=http://localhost:18080,http://127.0.0.1:18080
