## MySQL
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=jellyfish
MYSQL_USER=jellyfish
MYSQL_PASSWORD=change-me
MYSQL_PORT=3306

## Redis / Celery Broker
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=
# 如需单独覆盖完整 broker 地址，可设置：
# CELERY_BROKER_URL=redis://redis:6379/0

## Backend
# 可选：如需真实调用大模型，再设置
# OPENAI_API_KEY=

## RustFS (S3 compatible)
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
S3_BUCKET_NAME=jellyfish-assets
RUSTFS_PORT=9000
RUSTFS_CONSOLE_PORT=9001

## server.bat (docker compose 无头模式) 对外发布的端口
# 故意跟 test.bat/run.bat 本地开发模式用的 8000/5273 错开，
# 这样两种模式的端口永远不会互相冲突，可以随时切换。
SERVER_BACKEND_PORT=18000
# web/（日常创作用的 shotcat 工作台，唯一的日常前端）对外发布的端口。
# web/ 用相对路径 /api/*、/pipeline/* 调后端，由 Caddy 同源反代，
# 不需要单独的 CORS_ORIGINS/内部端口。
SERVER_WEB_PORT=18081
# 容器实际发布的"内部端口"，由 server.bat 的 portproxy 从上面的对外
# 端口转发过来（转发目标按 WSL 网络模式自动探测）。必须与对外端口
# 错开（避免 mirrored 模式按端口号整机记账造成冲突），一般不用改。
SERVER_BACKEND_INTERNAL_PORT=28000
# app/front（旧 Studio，仅维护用，见 docs/前端收敛方案-20260719.md）的容器
# 内部端口。默认不随 `docker compose up` 启动，也不经 server.bat 对外暴露；
# 需要维护时手动 `docker compose --profile legacy up -d --build front`，
# 再通过 SSH 端口转发访问该内部端口。
SERVER_FRONT_INTERNAL_PORT=28080

## app/front runtime config (served as /env.js)
# 仅供 app/front（旧 Studio，仅维护用）手动启动时使用，web/ 不需要这两项。
# 由于前后端分端口部署，浏览器应访问宿主机的后端地址。
# 注意：这里的 localhost 是相对"打开页面的浏览器"而言的，不是服务器自己。
# 只有浏览器和服务器是同一台机器时，localhost 才有效；
# 如果要给局域网/其他机器访问，必须换成服务器的真实局域网 IP，
# 例如 http://192.168.1.10:18000
BACKEND_URL=http://localhost:18000

# 跨域白名单（逗号分隔），必须跟浏览器访问 app/front 时地址栏里的
# “协议+主机+端口”完全一致（按 SERVER_FRONT_INTERNAL_PORT 或 SSH
# 转发到本机的端口填写）。局域网访问时需要把服务器的局域网 IP 也加进来。
CORS_ORIGINS=http://localhost:28080,http://127.0.0.1:28080
