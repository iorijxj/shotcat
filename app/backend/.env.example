# Jellyfish Backend - 环境变量示例
# 复制为 .env 后按需修改

# 应用
APP_NAME=Jellyfish API
DEBUG=false

# API
API_V1_PREFIX=/api/v1

# 数据库（默认 SQLite 异步）
# DATABASE_URL=sqlite+aiosqlite:///./jellyfish.db
# PostgreSQL 示例:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/jellyfish
# MySQL 示例（使用 aiomysql 驱动）:
# DATABASE_URL=mysql+aiomysql://user:pass@localhost:3306/jellyfish

# Redis / Celery Broker
# 默认情况下，若未单独指定 CELERY_BROKER_URL，系统会自动使用以下 Redis 配置拼接：
# redis://[:password@]host:port/db
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=
# 如需单独覆盖，可直接指定完整 broker URL：
# CELERY_BROKER_URL=redis://localhost:6379/0

# CORS 前端地址（逗号分隔）
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 鉴权（必填，启动时缺失会直接报错）：JWT 签名密钥，生产环境请用随机字符串，不要沿用示例值
# 生成方式参考：python -c "import secrets; print(secrets.token_hex(32))"
AUTH_JWT_SECRET=change-me-to-a-random-secret
# AUTH_JWT_EXPIRE_MINUTES=43200

# LLM Provider api_key/api_secret 静态加密密钥（必填，启动时缺失会直接报错）
# 生成方式：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 生产环境请用独立生成的随机值，不要沿用示例值；换密钥后已加密的存量数据需要重新迁移
PROVIDER_SECRET_ENC_KEY=change-me-to-a-random-fernet-key

# 弱口令启动校验（公众化 M1，安全默认）：留空/false 时检测到默认/弱口令
# （change-me、rustfsadmin 等）即拒绝启动。仅本机防火墙内开发对接本地 docker
# 基础设施时才设 true 豁免；任何公网部署保持 false 并使用随机强口令。
# ALLOW_WEAK_SECRETS=false

# 安全整改阶段三（均有默认值，按需覆盖）
# 登录防暴力破解：失败阈值与锁定秒数
# LOGIN_MAX_FAILURES_PER_USER=5
# LOGIN_MAX_FAILURES_PER_IP=30
# LOGIN_LOCKOUT_SECONDS=900
# 上传大小上限（MB，按类型区分；仅约束手动上传接口）
# UPLOAD_MAX_IMAGE_MB=2
# UPLOAD_MAX_VIDEO_MB=5
# SSRF 防护开关：仅本地用 localhost mock 供应商时临时置 true，部署环境保持 false
# SSRF_ALLOW_PRIVATE_TARGETS=false
# AI 生成类接口限流：每登录用户每分钟允许的生成请求数，0 关闭
# GENERATION_RATE_LIMIT_PER_MINUTE=10
# 登录接口限流（公众化 M1）：每来源 IP 每分钟允许的 /auth/login 请求数，0 关闭。
# 经 Caddy 反代时 IP 退化为网关地址，此值近似全局洪泛上限，按真实并发登录量调整。
# LOGIN_RATE_LIMIT_PER_MINUTE=60

# 图片生成（用于演员/角色/道具/场景/服装/镜头帧图片生成任务）
# IMAGE_API_PROVIDER=openai
# IMAGE_API_BASE_URL=https://example.com/v1/images/generations
# IMAGE_API_KEY=your-image-api-key

# 视频生成（用于 /film/generated_video 等接口）
# VIDEO_API_PROVIDER=openai
# VIDEO_API_BASE_URL=https://example.com/v1/videos/generations
# VIDEO_API_KEY=your-video-api-key

# S3 / 对象存储（素材文件）
# 如使用 AWS S3，可按需填写：
# S3_ENDPOINT_URL=https://s3.amazonaws.com
# S3_REGION_NAME=ap-southeast-1
# S3_ACCESS_KEY_ID=your-access-key-id
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_BUCKET_NAME=jellyfish-assets
# 可选统一前缀，方便按环境/项目隔离，如 jellyfish/dev
# S3_BASE_PATH=jellyfish/dev
# 若有 CDN/自定义域名，可配置成 https://cdn.example.com
# S3_PUBLIC_BASE_URL=
