# 密钥/凭证（绝不入库）
app/deploy/compose/.env
screenwriter/.glm_key
**/*.key

# 生成产物
screenwriter/*generated*.json
generated-story-bible.json

# Python
__pycache__/
*.pyc

# 依赖/构建
node_modules/
*.tsbuildinfo
bridge/.glm_key
bridge/.openai_key
bridge/.custom_key
bridge/.custom_base_url
bridge/.custom_model
bridge/visual-dict-*.json

# app/ 后端内核（已并入本仓库，作为项目自有代码维护）
# —— 仅忽略其运行产物与密钥（app/deploy/compose/.env 已在上方忽略）
app/**/node_modules/
app/**/__pycache__/
app/**/dist/
app/**/.env

# web/ 工作台构建产物（server.bat 每次起服务都会重新 build）
web/dist/

# 备份归档
/_archive/

# 生成产物
bridge/units-*.json
bridge/shots-*.json

# 本地二进制工具（server.bat 用的 LAN 反向代理，手动下载放置）
tools/caddy.exe

# 本地运行数据与日志
app/backend/jellyfish.db*
app/backend/local-storage/
jellyfish.db*
bridge/*.log
web/*.log
.tmp-openapi.json
